-- 0.01 Initial version
project Fast_Sequential_Summation is
    -- Specify source, object, and executable directories
    for Source_Dirs use (".");
    for Object_Dir use "obj";
    for Exec_Dir use ".";

    -- Main program
    for Main use ("fast_sequential_summation.adb");

    -- Compiler options
    package Compiler is
        for Default_Switches ("Ada") use ("-O2", "-gnatwa"); -- Optimization and warnings
    end Compiler;
end Fast_Sequential_Summation;
